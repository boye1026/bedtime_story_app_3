# ===== 应用密钥 =====
# 用于 Session 加密等安全用途，生产环境务必修改
SECRET_KEY=your-secret-key-change-in-production

# ===== 数据库配置 =====
# SQLite（开发环境默认）
DATABASE_URL=sqlite:///bedtime_stories.db
# MySQL 示例（生产环境）: mysql+pymysql://user:password@localhost:3306/story_db
# PostgreSQL 示例: postgresql://user:password@localhost:5432/story_db

# ===== 通义千问 AI 配置 =====
# 在阿里云 DashScope 控制台申请: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
# 兼容 OpenAI SDK 的 API 地址（默认无需修改）
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型名称（可选: qwen-turbo, qwen-plus, qwen-max）
QWEN_MODEL=qwen-turbo
# AI 生成超时时间（秒）
QWEN_TIMEOUT=60

# ===== 业务配置 =====
# 每日免费生成次数
FREE_DAILY_COUNT=1
# 观看广告奖励次数
AD_REWARD_COUNT=1

# ===== Flask 环境 =====
FLASK_ENV=development
